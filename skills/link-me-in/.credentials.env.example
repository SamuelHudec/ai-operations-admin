# Copy this file to .credentials.env and fill values.
# This example file is safe to commit. Never commit .credentials.env.

# LinkedIn official app credentials
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# The exact OAuth redirect URI configured in the LinkedIn app
# Example: http://localhost:8765/callback
LINKEDIN_REDIRECT_URI=

# Optional local override for token storage
# LINKEDIN_MCP_TOKEN_STORE=/absolute/path/to/linkedin_tokens.json
