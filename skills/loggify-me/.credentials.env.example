# Copy this file to .credentials.env and fill values.
# This example file is safe to commit. Never commit .credentials.env.

CLOCKIFY_WORKSPACE_ID=
CLOCKIFY_API_KEY=
CLOCKIFY_DEFAULT_PROJECT_ID=

# Personal workload settings (used for planning)
# Format: comma-separated day keys from mon,tue,wed,thu,fri,sat,sun
WORK_DAYS=mon,tue,wed,thu,fri
DAILY_TARGET_HOURS=8
USER_TIMEZONE=Europe/Prague

# Calendar ICS source (set one)
CALENDAR_ICS_URL=
# CALENDAR_ICS_FILE=/absolute/path/to/calendar.ics
